{
  "manifest_version": 3,
  "name": "Quick Google Search",
  "version": "1.0.0",
  "description": "選択したテキストをワンクリックでGoogle検索できます。",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
