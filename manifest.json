{
  "manifest_version": 3,
  "name": "Quick Search Plus",
  "version": "1.1.0",
  "description": "Shows a Google search icon near selected text, plus an optional character count for longer selections.",
  "permissions": ["storage"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
